{
    "name": "freyr/kafka-php-workshop",
    "description": "PHP + Kafka workshop — runnable examples and exercises for a 2-day curriculum. Built on Confluent Platform and php-rdkafka.",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "ext-rdkafka": "^6.0",
        "ext-json": "*",
        "ext-pcntl": "*",
        "ext-sockets": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "Workshop\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Workshop\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true,
        "platform": {
            "php": "8.3.0"
        },
        "allow-plugins": {}
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
