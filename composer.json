{
    "name": "freyr/kafka-php-workshop",
    "description": "PHP + Kafka workshop — runnable examples and exercises for a 2-day curriculum. Built on Confluent Platform, php-rdkafka and enqueue/rdkafka.",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.4",
        "ext-json": "*",
        "ext-pcntl": "*",
        "ext-rdkafka": "^6.0",
        "ext-sockets": "*",
        "doctrine/dbal": "^4.4",
        "enqueue/rdkafka": "^0.10",
        "flix-tech/avro-serde-php": "^3.0",
        "symfony/config": "^7.4",
        "symfony/console": "^7.4",
        "symfony/dependency-injection": "^7.4",
        "symfony/dotenv": "^7.4",
        "symfony/uid": "^8.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^11.5",
        "symplify/easy-coding-standard": "^12.5"
    },
    "autoload": {
        "psr-4": {
            "Workshop\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Workshop\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "ecs": "ecs check",
        "ecs-fix": "ecs check --fix",
        "phpstan": "phpstan analyse --memory-limit=512M"
    },
    "config": {
        "sort-packages": true,
        "platform": {
            "php": "8.4.0"
        },
        "allow-plugins": {}
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
