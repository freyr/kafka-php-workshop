#!/usr/bin/env bash
set -euo pipefail

# Registers the Debezium MySQL outbox connector (Block 6 — CDC relay). Waits for
# the Kafka Connect REST API, pre-creates the routed + schema-history topics
# (broker auto-create is off), then (re)creates the connector from
# config/debezium-outbox-connector.json.
#
# Always a CLEAN start, so re-running converges no matter what happened before:
#
#  - Kafka Connect keeps source offsets in connect_offsets KEYED BY CONNECTOR
#    NAME, and they SURVIVE connector deletion. If schema-history.outbox was
#    recreated in between (make teardown / make integration do exactly that), a
#    plain re-register dies on startup with "The db history topic is missing".
#    So the connector is created in STOPPED state (no task ever runs against
#    stale offsets), its framework-managed offsets are purged, and only then is
#    it resumed.
#  - The script then waits for the TASK to report RUNNING: a connector can be
#    RUNNING while its only task is FAILED, which is invisible unless asked.

CONNECT_URL="${CONNECT_URL:-http://localhost:8083}"
ROOT="$(cd "$(dirname "$0")/.." && pwd)"
CONFIG="${ROOT}/config/debezium-outbox-connector.json"
NAME="$(sed -n 's/.*"name"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$CONFIG" | head -n1)"

echo "waiting for Kafka Connect at ${CONNECT_URL} …"
for _ in $(seq 1 60); do
  if curl -fsS "${CONNECT_URL}/" >/dev/null 2>&1; then break; fi
  sleep 2
done
curl -fsS "${CONNECT_URL}/" >/dev/null || { echo "Kafka Connect is not reachable — is the stack up? Try 'make create'." >&2; exit 1; }

# Output + schema-history topics: the broker has auto-create disabled, so the
# connector cannot create them itself. Make them explicitly (idempotent).
for entry in "enet.ecommerce.outbox.Order:6" "schema-history.outbox:1"; do
  topic="${entry%%:*}"; partitions="${entry##*:}"
  echo "ensuring topic ${topic} (${partitions} partitions)…"
  docker compose exec -T kafka kafka-topics \
    --bootstrap-server kafka:29092 --create --if-not-exists \
    --topic "$topic" --partitions "$partitions" --replication-factor 1
done

echo "dropping any existing '${NAME}' …"
curl -fsS -X DELETE "${CONNECT_URL}/connectors/${NAME}" >/dev/null 2>&1 || true

# Create in STOPPED state (KIP-980): the config file's first line is the opening
# brace, so initial_state is injected right after it.
echo "creating '${NAME}' (stopped) …"
{ echo '{'; echo '  "initial_state": "STOPPED",'; tail -n +2 "$CONFIG"; } \
  | curl -fsS -X POST "${CONNECT_URL}/connectors" \
      -H 'Content-Type: application/json' --data-binary @- >/dev/null

echo "purging stale source offsets …"
curl -fsS -X DELETE "${CONNECT_URL}/connectors/${NAME}/offsets" >/dev/null

echo "resuming '${NAME}' …"
curl -fsS -X PUT "${CONNECT_URL}/connectors/${NAME}/resume"

echo "waiting for the task to report RUNNING …"
state=""
for _ in $(seq 1 30); do
  status="$(curl -fsS "${CONNECT_URL}/connectors/${NAME}/status" 2>/dev/null || true)"
  state="$(printf '%s' "$status" | sed -n 's/.*"tasks":\[{[^}]*"state":"\([A-Z]*\)".*/\1/p')"
  [ "$state" = "RUNNING" ] && break
  [ "$state" = "FAILED" ] && break
  sleep 2
done

if [ "$state" != "RUNNING" ]; then
  echo
  echo "✗ task is ${state:-not up} — full status:" >&2
  curl -fsS "${CONNECT_URL}/connectors/${NAME}/status" >&2 || true
  echo >&2
  exit 1
fi

echo
echo "✓ registered, task RUNNING. Place an order and watch CDC route it"
echo "(the topic carries JSON, not AVRO):"
echo "  docker compose run --rm php bin/console outbox:place"
echo "  make outbox-watch"
echo
echo "note: outbox:relay is the other relay flavor for the same table — run one"
echo "flavor at a time, or both publish the same rows."
