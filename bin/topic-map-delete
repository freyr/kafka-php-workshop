#!/usr/bin/env bash
set -euo pipefail

# Tears down the topics created by bin/topic-map. Safe to run repeatedly
# (--if-exists). Keep this list in sync with bin/topic-map.
TOPICS=(
  enet.ecommerce.orders
  enet.ecommerce.payments
  enet.ecommerce.inventory
  enet.ecommerce.users
  enet.ecommerce.notifications
  enet.internal.dead-letters
)

for topic in "${TOPICS[@]}"; do
  echo "deleting ${topic}…"
  docker compose exec -T kafka kafka-topics \
    --bootstrap-server kafka:29092 \
    --delete --topic "$topic" --if-exists
done
