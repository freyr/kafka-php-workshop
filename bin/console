#!/usr/bin/env php
<?php

declare(strict_types=1);

require __DIR__ . '/../vendor/autoload.php';

// Keep workshop output clean: hide deprecation notices emitted by third-party
// libraries (e.g. the schema-registry client) under PHP 8.4.
error_reporting(E_ALL & ~E_DEPRECATED);

use Symfony\Component\Console\Application;
use Symfony\Component\Console\Command\Command;
use Symfony\Component\Dotenv\Dotenv;
use Workshop\Framework\Kernel;

(new Dotenv())->bootEnv(__DIR__ . '/../.env');

$container = (new Kernel(dirname(__DIR__)))->boot();

$app = new Application('kafka-php-workshop', 'dev');
foreach (array_keys($container->findTaggedServiceIds('console.command')) as $id) {
    $command = $container->get($id);
    if ($command instanceof Command) {
        $app->addCommand($command);
    }
}

exit($app->run());
