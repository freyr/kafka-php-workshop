<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
         cacheDirectory=".phpunit.cache"
         failOnWarning="true"
         failOnRisky="true">
    <testsuites>
        <testsuite name="workshop">
            <directory>tests</directory>
        </testsuite>
    </testsuites>
    <!-- ignoreIndirectDeprecations: drop deprecations triggered in third-party
         code (e.g. the schema-registry client under PHP 8.4) — outside our control
         and already silenced at runtime in bin/console. Deprecations in our own
         src/ still surface and would fail the suite. -->
    <source ignoreIndirectDeprecations="true">
        <include>
            <directory>src</directory>
        </include>
    </source>
</phpunit>
